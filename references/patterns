## 24. MULTI-CLICK CURSOR

When the scenario has N sequential clicks (e.g. clicking 4 variable pills), extend pattern #14 with an array.

```tsx
// All click frames in an array — order = sequence
const ALL_CLICKS = [TL.click1, TL.click2, TL.click3, TL.click4];

function MultiCursor({ frame, fps }: { frame: number; fps: number }) {
  if (frame < TL.cursorIn || frame > TL.cursorOut + 12) return null;
  const pos = getCursorPos(CURSOR_WPS, frame, fps); // same getCursorPos from pattern #14
  const o   = fade(frame, TL.cursorIn, 10) * fdOut(frame, TL.cursorOut, 14);

  // Find the most recent active click within the ripple window (22f)
  let clickDt = -1;
  for (const c of ALL_CLICKS) {
    const dt = frame - c;
    if (dt >= 0 && dt <= 22) clickDt = dt;
  }
  const isClick = clickDt >= 0;
  const dotSc   = isClick ? 1 - 0.4 * Math.sin((clickDt / 22) * Math.PI) : 1;
  const ringR   = isClick ? interpolate(clickDt, [0, 22], [14, 38], clamp) : 14;
  const ringO   = isClick ? interpolate(clickDt, [0, 4, 22], [0, 1, 0], clamp) : 0;

  return (
    <div style={{ position: "absolute", left: 0, top: 0, opacity: o, pointerEvents: "none", zIndex: 300 }}>
      <div style={{
        position: "absolute", left: pos.x - ringR, top: pos.y - ringR,
        width: ringR * 2, height: ringR * 2, borderRadius: "50%",
        border: "2px solid rgba(14,16,41,0.85)", opacity: ringO,
      }} />
      <div style={{
        position: "absolute", left: pos.x - 10, top: pos.y - 10,
        width: 20, height: 20, borderRadius: "50%",
        background: T.navy, boxShadow: "0 0 0 3px rgba(255,255,255,0.90)",
        transform: `scale(${dotSc})`, transformOrigin: "center center",
      }} />
    </div>
  );
}

// Waypoints: cursor starts off-screen, visits each target, lingers after last click
const CURSOR_WPS: WP[] = [
  { f: TL.cursorIn,         x: 1420, y: 650 },              // appears off-canvas
  { f: TL.cur1At,           x: TARGET1_X, y: TARGET1_Y },   // glides to pill 1
  { f: TL.click1 + 12,     x: TARGET1_X, y: TARGET1_Y },   // holds after click
  { f: TL.cur2At - 6,      x: TARGET2_X, y: TARGET2_Y },   // starts moving to pill 2
  { f: TL.cur2At,          x: TARGET2_X, y: TARGET2_Y },
  { f: TL.click2 + 12,     x: TARGET2_X, y: TARGET2_Y },
  // ... repeat for N clicks
];
```

**Waypoint pattern per click:** `curXAt - 6` (start moving) → `curXAt` (arrive) → `clickX + 12` (hold after ripple). The `-6` gives the spring time to start decelerating.

