## 6. CALLOUT OVERLAY (End Card / CTA)

This is the standard end-card component. Every video should end with this.
Place it in screen space (outside the camera div).

```tsx
const CalloutOverlay: React.FC<{ frame: number; startAt: number; fps: number }> = ({ frame, startAt, fps }) => {
  const o  = fade(frame, startAt, 25);
  const s  = spr(frame, startAt, fps, { damping: 18, stiffness: 100 });
  const sc = interpolate(s, [0, 1], [0.88, 1]);

  const features = ["Feature 1", "Feature 2", "Feature 3"]; // customize per video

  return (
    <div style={{ position: "absolute", inset: 0, opacity: o, pointerEvents: "none", zIndex: 100 }}>
      {/* Backdrop */}
      <div style={{
        position: "absolute", inset: 0,
        background: "rgba(8,10,28,0.65)", backdropFilter: "blur(4px)",
      }} />
      {/* Card */}
      <div style={{
        position: "absolute", top: "50%", left: "50%",
        transform: `translate(-50%, -50%) scale(${sc})`,
        background: T.surface, borderRadius: 18, padding: "44px 56px",
        boxShadow: "0 48px 120px rgba(0,0,0,0.45)",
        maxWidth: 640, width: 640, textAlign: "center",
        fontFamily: T.font,
      }}>
        {/* Label chip */}
        <div style={{
          fontSize: 11, fontWeight: 700, color: T.accent,
          letterSpacing: 2.5, textTransform: "uppercase", marginBottom: 16,
        }}>
          PILOC · [FEATURE NAME]
        </div>
        {/* Headline — benefit, not feature */}
        <div style={{ fontSize: 30, fontWeight: 700, color: T.text, lineHeight: 1.3, marginBottom: 18 }}>
          [Main benefit, max 2 lines]
        </div>
        {/* Body */}
        <div style={{ fontSize: 15, color: T.muted, lineHeight: 1.75, marginBottom: 30 }}>
          [1–2 lines supporting description]
        </div>
        {/* Feature pills */}
        <div style={{ display: "flex", gap: 10, justifyContent: "center", flexWrap: "wrap" }}>
          {features.map((feat, i) => {
            const pillO = fade(frame, startAt + 15 + i * 8, 15);
            return (
              <span key={feat} style={{
                background: "rgba(157,184,238,0.15)", color: T.accent,
                borderRadius: 99, fontSize: 13, fontWeight: 600, padding: "7px 18px",
                opacity: pillO,
              }}>{feat}</span>
            );
          })}
        </div>
      </div>
    </div>
  );
};
```

