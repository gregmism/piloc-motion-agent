## 2. HELPERS

Define these at the top of every file. Never inline these patterns.

```ts
// Clamp shorthand — use on every interpolate call
const clamp = { extrapolateLeft: "clamp" as const, extrapolateRight: "clamp" as const };

// Fade in: opacity 0→1 over d frames starting at s
const fade  = (f: number, s: number, d = 20) => interpolate(f, [s, s + d], [0, 1], clamp);

// Fade out: opacity 1→0 over d frames starting at s
const fdOut = (f: number, s: number, d = 20) => interpolate(f, [s, s + d], [1, 0], clamp);

// Spring helper with startAt offset
function spr(frame: number, startAt: number, fps: number, cfg = { damping: 22, stiffness: 140 }) {
  return spring({ frame: frame - startAt, fps, config: cfg });
}

// French number formatter
const fr = (n: number) => n.toLocaleString("fr-FR");
```

**Usage pattern for combined fade-in + fade-out:**
```ts
// Element that fades in then fades out:
const o = fade(frame, TL.sceneIn, 16) * fdOut(frame, TL.sceneOut, 14);
style={{ opacity: o }}
```

