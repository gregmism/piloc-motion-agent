## 5. ANIMATION PATTERNS

### Fade + slide entry (most common)

```ts
const o  = fade(frame, startAt);          // opacity 0→1
const ty = interpolate(frame, [startAt, startAt + 20], [12, 0], clamp); // translateY
// Apply: style={{ opacity: o, transform: `translateY(${ty}px)` }}
```

### Staggered list items

```tsx
{items.map((item, idx) => {
  const startAt = baseStart + idx * 6; // 6 frames between each item (validated)
  const o  = fade(frame, startAt);
  const ty = interpolate(frame, [startAt, startAt + 20], [10, 0], clamp);
  return <Item key={item.id} style={{ opacity: o, transform: `translateY(${ty}px)` }} />;
})}
```

### KPI count-up

```ts
const val = Math.round(interpolate(frame, [startAt, startAt + 35], [0, target], clamp));
// Render: {prefix}{val.toLocaleString("fr-FR")}{suffix}
```

### KPI bounce (number updates live)

```ts
// Single sin-pulse bump when a value increments
const dt = frame - TL.kpiBounce;
const kpiScale = dt >= 0 ? 1 + 0.18 * Math.sin(Math.min(1, dt / 18) * Math.PI) : 1;
// Apply: style={{ transform: `scale(${kpiScale})`, transformOrigin: "center center" }}
```

### Spring pop (badge appears)

```ts
const badgeSc = frame >= startAt
  ? spring({ frame: frame - startAt, fps: 30, config: { damping: 13, stiffness: 220 } })
  : 0;
// Apply: style={{ transform: `scale(${badgeSc})`, transformOrigin: "left center" }}
```

### Color interpolation between two colors

```ts
// Define RGB components as const tuples
const ACCENT_RGB = [157, 184, 238] as const;
const ERROR_RGB  = [236, 99,  105] as const;

const t = interpolate(frame, [startAt, startAt + 20], [0, 1], clamp);
const barColor = `rgb(
  ${Math.round(interpolate(t, [0, 1], [ACCENT_RGB[0], ERROR_RGB[0]]))},
  ${Math.round(interpolate(t, [0, 1], [ACCENT_RGB[1], ERROR_RGB[1]]))},
  ${Math.round(interpolate(t, [0, 1], [ACCENT_RGB[2], ERROR_RGB[2]]))}
)`;
```

### Row highlight (blur + scale focus)

```tsx
// When a row becomes the focal point: scale it up, blur everything else
const hp = frame >= TL.highlight
  ? spring({ frame: frame - TL.highlight, fps: 30, config: { damping: 28, stiffness: 120 } })
  : 0;
const scale      = isHighlighted ? interpolate(hp, [0, 1], [1, 1.06]) : 1;
const blurAmt    = !isHighlighted && frame >= TL.highlight
  ? interpolate(frame, [TL.highlight, TL.highlight + 20], [0, 3.5], clamp)
  : 0;
const shadowAlpha = interpolate(hp, [0, 1], [0, 0.16]);

// Row style:
style={{
  transform: `scale(${scale})`,
  filter: isHighlighted ? "none" : `blur(${blurAmt}px)`,
  boxShadow: isHighlighted ? `0 16px 52px rgba(14,16,41,${shadowAlpha})` : "none",
  zIndex: isHighlighted ? 10 : 1,
  position: "relative",
}}
```

### Badge flip (status changes)

```ts
const rawFlip = interpolate(frame, [TL.flip, TL.flip + 25], [0, 180], clamp);
const scaleX  = Math.abs(Math.cos((rawFlip * Math.PI) / 180));
const showFront = rawFlip <= 90;

// Render:
<div style={{ transform: `scaleX(${scaleX})`, display: "inline-flex" }}>
  {showFront ? <Badge type="pending" label="Non validée" /> : <Badge type="validated" label="Validée" />}
</div>
```

### Progress bar (animated fill)

```ts
const filled = interpolate(frame, [startAt, startAt + 40], [0, targetPct], clamp);
// Render:
<div style={{ background: "#f0f0f0", borderRadius: 99, height: 6, overflow: "hidden", width: 100 }}>
  <div style={{ height: "100%", borderRadius: 99, background: color, width: `${filled}%` }} />
</div>
```

### Row background flash (action confirmation)

```ts
const flashO = interpolate(frame, [actionAt, actionAt + 6, actionAt + 25], [0, 0.18, 0], clamp);
const rowBg  = flashO > 0 ? `rgba(50,149,71,${flashO})` : "transparent"; // success flash
// Apply to row: style={{ background: rowBg }}
```

### SVG donut chart (animated segments)

```ts
const r = 35, cx = 45, cy = 45, sw = 13;
const circ = 2 * Math.PI * r; // ≈ 219.9

// Each segment: precompute dashLen and cumulative offset
const segments = [
  { color: T.accent,  dashLen: 61.6,  offset: 0 },
  { color: T.success, dashLen: 68.2,  offset: 61.6 },
  { color: T.error,   dashLen: 11.0,  offset: 129.8 },
];

// Render:
{segments.map((seg, i) => {
  const animLen = interpolate(frame, [startAt + i * 10, startAt + i * 10 + 30], [0, seg.dashLen], clamp);
  return (
    <circle key={i} cx={cx} cy={cy} r={r} fill="none" stroke={seg.color} strokeWidth={sw}
      strokeDasharray={`${animLen} ${circ}`}
      strokeDashoffset={-seg.offset}
      style={{ transform: "rotate(-90deg)", transformOrigin: `${cx}px ${cy}px` }}
    />
  );
})}
```

### SVG line chart with clipPath reveal (more robust than strokeDashoffset for area fills)

```tsx
const clipWidth = interpolate(frame, [startAt, startAt + 50], [0, 290], clamp);

<svg width="100%" viewBox="0 0 290 60" preserveAspectRatio="none">
  <defs>
    <linearGradient id="lineGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stopColor={T.accent} stopOpacity={0.25} />
      <stop offset="100%" stopColor={T.accent} stopOpacity={0.02} />
    </linearGradient>
    <clipPath id="lineClip">
      <rect x="0" y="0" width={clipWidth} height="60" />
    </clipPath>
  </defs>
  {/* Fill area — clipped to reveal left-to-right */}
  <polygon
    points="0,48 35,42 80,35 125,26 165,17 210,9 280,3 280,60 0,60"
    fill="url(#lineGrad)"
    clipPath="url(#lineClip)"
  />
  {/* Line */}
  <polyline
    points="0,48 35,42 80,35 125,26 165,17 210,9 280,3"
    fill="none" stroke={T.accent} strokeWidth={2.5}
    strokeDasharray={320}
    strokeDashoffset={interpolate(frame, [startAt, startAt + 50], [320, 0], clamp)}
  />
</svg>
```

