## 7. TEXT OVERLAY (Caption / Action Label)

Burned-in text overlay for LinkedIn muted-autoplay. Place in screen space.

```tsx
interface TextOverlayProps {
  frame: number;
  showAt: number;
  hideAt: number;
  text: string;
}

const TextOverlay: React.FC<TextOverlayProps> = ({ frame, showAt, hideAt, text }) => {
  const o = Math.min(
    interpolate(frame, [showAt, showAt + 12], [0, 1], clamp),
    interpolate(frame, [hideAt - 10, hideAt], [1, 0], clamp),
  );
  if (o <= 0) return null;
  return (
    <div style={{
      position: "absolute", bottom: 80, left: "50%",
      transform: "translateX(-50%)",
      background: "rgba(14,16,41,0.65)", backdropFilter: "blur(2px)",
      borderRadius: 8, padding: "8px 20px",
      fontSize: 18, fontWeight: 600, color: "#ffffff",
      whiteSpace: "nowrap", fontFamily: T.font,
      opacity: o, zIndex: 200,
    }}>
      {text}
    </div>
  );
};

// Usage in main composition (screen space):
<TextOverlay frame={frame} showAt={TL.camZoom + 18} hideAt={TL.camZoom + 80} text="Statut payeur en temps réel" />
<TextOverlay frame={frame} showAt={TL.action}      hideAt={TL.action + 60}   text="Paiement validé automatiquement" />
```

