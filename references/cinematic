## Animation Vocabulary — Cinematic Style
 
### Glitch Entry (kinetic typography)
```ts
// Glitch text in — deterministic offset
// NEVER use Math.random() in Remotion — it is non-deterministic and causes flickering between frames.
// Use frame-derived pseudo-noise instead:
const glitchOffset = frame < 3 ? Math.sin(frame * 137.5) * 4 : 0;
const opacity = interpolate(frame, [0, 4], [0, 1], { extrapolateRight: "clamp" });
const translateX = frame < 3 ? glitchOffset : 0;

// Color channel split (RGB offset effect)
// Render text 3 times: red, green, blue channels offset by 2–4px, fade out after 6 frames
const channelOffset = interpolate(frame, [0, 6], [4, 0], { extrapolateRight: "clamp" });
```
 
### High-Velocity Slide (text entry)
```ts
// Text rockets in from off-screen, decelerates sharply
const translateX = interpolate(frame, [0, 8], [-200, 0], {
  easing: Easing.out(Easing.cubic),
  extrapolateRight: 'clamp',
});
```
 
### Particle / Neural Network Reveal
```ts
// Each particle fades in at staggered frames
// Use index-based offset: particle i starts at frame i * 2
const particleOpacity = (index: number) =>
  interpolate(frame - index * 2, [0, 10], [0, 1], { extrapolateLeft: 'clamp' });
```
 
### UI Dashboard Assembly
```ts
// Panels slide in from different directions with spring
const panelScale = spring({ frame, fps, config: { stiffness: 80, damping: 20 } });
const panelOpacity = interpolate(frame, [0, 20], [0, 1]);
 
// Stagger each panel by 8 frames
const panel1From = 0;
const panel2From = 8;
const panel3From = 16;
```
 
### Rim Light Glow (UI elements)
```ts
// CSS filter glow that pulses
const glowIntensity = interpolate(
  Math.sin((frame / 30) * Math.PI * 2), // 1 cycle per second
  [-1, 1],
  [8, 16]
);
// Apply as: style={{ filter: `drop-shadow(0 0 ${glowIntensity}px #00D4FF)` }}
```
 
### Motion Blur (fast camera moves)
```ts
// Use @remotion/motion-blur package
import { CameraMotionBlur } from '@remotion/motion-blur';
 
// Wrap fast-moving elements
<CameraMotionBlur shutterAngle={180} samples={10}>
  <FastMovingElement />
</CameraMotionBlur>
```
 
### Scale Zoom (dramatic push-in)
```ts
const scale = interpolate(frame, [0, durationInFrames], [1, 1.15], {
  easing: Easing.inOut(Easing.ease),
});
// Apply to background or UI element for Ken Burns / push-in effect
```
 
