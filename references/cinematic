### Trailer composition pattern
 
```tsx
// CinematicLaunch.tsx — top level uses Sequence (scenes can crossfade)
export const CinematicLaunch = () => (
  <AbsoluteFill style={{ background: '#080808' }}>
    <Sequence from={0}    durationInFrames={460}><Hook /></Sequence>
    <Sequence from={440}  durationInFrames={770}><Problem /></Sequence>   // 20-frame crossfade
    <Sequence from={1195} durationInFrames={915}><Reveal /></Sequence>
    <Sequence from={2100} durationInFrames={600}><Climax /></Sequence>
    <Sequence from={0}    durationInFrames={2700}>
      <Audio src={staticFile('track.mp3')} volume={1} />
    </Sequence>
  </AbsoluteFill>
);
 
// Climax.tsx — rapid-fire montage uses Series (sequential, no gaps, no manual frame math)
const FEATURE_CUTS = [
  { label: 'FASTER', shot: 'kpi-dashboard' },
  { label: 'SMARTER', shot: 'neural-abstract' },
  { label: 'AUTOMATED', shot: 'workflow' },
  { label: 'UNIFIED', shot: 'team-feed' },
  { label: 'POWERFUL', shot: 'particle-burst' },
  { label: 'PRECISE', shot: 'alert-resolved' },
  { label: 'EVERYWHERE', shot: 'multi-device' },
  { label: 'YOURS', shot: 'logo-close' },
];
const CUT_FRAMES = 45; // 1.5s @ 30fps — snaps to 140BPM beat
 
export const Climax = () => (
  <AbsoluteFill>
    <Series>
      {FEATURE_CUTS.map(({ label, shot }) => (
        <Series.Sequence key={label} durationInFrames={CUT_FRAMES}>
          <FeatureCut label={label} shot={shot} />
        </Series.Sequence>
      ))}
    </Series>
    <Sequence from={FEATURE_CUTS.length * CUT_FRAMES} durationInFrames={240}>
      <LogoAssembly />
    </Sequence>
  </AbsoluteFill>
);
```
 
