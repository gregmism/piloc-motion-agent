## File Architecture — Cinematic Launch

Same single-file architecture as all Piloc videos. Everything lives in one `[Feature]Demo.tsx`.
Internal scene components (Hook, Reveal, Climax…) are defined as local functions within the same file — not separate files.

```
remotion/src/
├── index.tsx                ← register composition here
├── fonts.ts                 ← waitForInter()
├── Icons.tsx                ← SVG icons + PilocLogo
└── videos/
    └── CinematicLaunch.tsx  ← single self-contained file
```

### Scene structure pattern (within the single file)

```tsx
// Background: #0E1029 (navy) for LinkedIn — pure black cold open is forbidden.
// #080808 is acceptable for YouTube-only cinematic standalone.
import React from "react";
import { AbsoluteFill, Audio, interpolate, spring, staticFile, useCurrentFrame, useVideoConfig } from "remotion";
import { PilocLogo } from "../Icons";
import { waitForInter } from "../fonts";

const T = {
  navy: "#0E1029", mist: "#9DB8EE", surface: "#ffffff",
  text: "#112431", muted: "#6b7280", font: "'Inter', sans-serif",
};

// All scene components are local functions — no separate files.
const HookScene = ({ frame }: { frame: number }) => {
  if (frame < TL.hookIn || frame >= TL.hookOut) return null;
  const f = frame - TL.hookIn;
  // ... animations using f (local frame)
  return <AbsoluteFill style={{ background: T.navy }}>...</AbsoluteFill>;
};

// Rapid-fire montage — use Series for clean beat-sync cuts (no manual frame math)
const FEATURE_CUTS = [
  { label: "ENCAISSEZ", subline: "sans friction" },
  { label: "RELANCEZ",  subline: "automatiquement" },
  { label: "PILOTEZ",   subline: "en temps réel" },
];
const CUT_FRAMES = 45; // 1.5s @ 30fps — snaps to 140BPM beat

// Main export — frame-based architecture, all scenes as AbsoluteFill layers
export const CinematicLaunch = () => {
  const { fps } = useVideoConfig();
  const frame = useCurrentFrame();
  return (
    <AbsoluteFill style={{ background: T.navy }}>
      <Audio src={staticFile("music/track.mp3")} volume={0.45} startFrom={0} />
      <HookScene frame={frame} />
      <ProblemScene frame={frame} />
      <RevealScene frame={frame} />
      <ClimaxScene frame={frame} />
      <CtaScene frame={frame} />
    </AbsoluteFill>
  );
};
````